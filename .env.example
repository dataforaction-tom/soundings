# Copy to .env (git-ignored). For dev, any password works.
POSTGRES_PASSWORD=changeme-locally

# Soundings runtime
SOUNDINGS_LOG_LEVEL=info
SOUNDINGS_ENV=dev

# Adapter API keys
# CHARITY_COMMISSION_API_KEY=  # parked for future detail enrichment; bulk loader doesn't need it
# STATXPLORE_API_KEY=          # DWP Stat-Xplore; required for live Stat-Xplore tests
# NOMIS_API_KEY=               # ONS Nomis (MYE / Census / APS); optional, raises rate limit
