{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "jsx": "preserve",
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": false
  },
  "include": ["src/**/*", "tests/**/*", "*.config.*"],
  "exclude": ["dist", "node_modules"]
}
