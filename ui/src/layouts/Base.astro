---
import ConsentBanner from "../components/ConsentBanner.astro";

interface Props {
  title?: string;
}

const { title = "Soundings" } = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      body {
        font-family: system-ui, sans-serif;
        max-width: 56rem;
        margin: 2rem auto;
        padding: 0 1rem;
        line-height: 1.5;
      }
      header a {
        text-decoration: none;
        color: inherit;
      }
      footer {
        margin-top: 4rem;
        padding-top: 1rem;
        border-top: 1px solid #ddd;
        font-size: 0.875rem;
        color: #555;
      }
    </style>
  </head>
  <body>
    <header>
      <h1><a href="/">Soundings</a></h1>
    </header>
    <ConsentBanner />
    <main>
      <slot />
    </main>
    <footer>
      <a href="/about">About</a> · <a href="https://github.com/dataforaction-tom/soundings">GitHub</a>
    </footer>
  </body>
</html>
