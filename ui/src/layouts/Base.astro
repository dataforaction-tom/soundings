---
import ConsentBanner from "../components/ConsentBanner.astro";
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Soundings" } = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" />
  </head>
  <body>
    <header>
      <div class="header-inner">
        <h1><a href="/">Soundings</a></h1>
        <p class="tagline">Data for local decision-making</p>
      </div>
    </header>
    <ConsentBanner />
    <main>
      <slot />
    </main>
    <footer>
      <a href="/explore">Explore map</a> · <a href="/corpus">Corpus</a> · <a href="/about">About</a> · <a href="https://github.com/dataforaction-tom/soundings">GitHub</a>
    </footer>
  </body>
</html>

<style>
  body {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-xl) var(--space-md);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  header {
    margin-bottom: var(--space-xl);
  }

  .header-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  header h1 {
    margin: 0;
    font-size: var(--font-size-3xl);
  }

  header h1 a {
    color: var(--color-primary);
    text-decoration: none;
  }

  header h1 a:hover {
    color: var(--color-accent);
  }

  .tagline {
    margin: 0;
    color: var(--color-muted);
    font-size: var(--font-size-lg);
  }

  main {
    flex: 1;
  }

  footer {
    margin-top: var(--space-3xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
    font-size: var(--font-size-sm);
    color: var(--color-muted);
  }
</style>
