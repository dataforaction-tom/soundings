---
import Base from "../layouts/Base.astro";
import AskBox from "../components/AskBox.astro";

export const prerender = false;

const url = new URL(Astro.request.url);
const query = (url.searchParams.get("q") ?? "").trim();
const placeId = url.searchParams.get("place_id") ?? "";
const mode = url.searchParams.get("mode") ?? "summary";

// Browser-facing base for the streaming /v1/ask + block-data fetches. These run
// in the visitor's browser, so they must NOT use the internal `SOUNDINGS_API_BASE`
// (e.g. `http://server:8000`), which is only resolvable inside the Docker network.
// Default to same-origin relative paths, served through Caddy (which proxies
// `/v1/*` to the API) — matching how ConsentBanner already calls the API. Override
// with `SOUNDINGS_PUBLIC_API_BASE` only when the API is on a different public host.
const apiBase =
  (typeof process !== "undefined" && process.env.SOUNDINGS_PUBLIC_API_BASE) || "";
---

<Base title={query ? `Ask: ${query}` : "Ask"}>
  <header class="ask-header">
    <h1>{query ? query : "Ask a question"}</h1>
    {placeId && (
      <p class="place-context">About place <code>{placeId}</code></p>
    )}
  </header>

  <AskBox placeId={placeId || undefined} />

  {query ? (
    <div id="answer-surface" class="answer-surface" data-api-base={apiBase} data-query={query} data-mode={mode} data-place-id={placeId}>
      <p class="answer-status">Thinking…</p>
    </div>
  ) : (
    <p class="ask-prompt">Type a question above to get started.</p>
  )}

  <div id="answer-sources" class="answer-sources"></div>


  {/* The page logic lives in a real module so Astro bundles + transpiles it.
      A 750-line inline TS <script> here was emitted raw (untranspiled),
      crashing the browser on the first type annotation. The module's own
      `if (surface)` guard no-ops when there's no question. */}
  <script>
    import "../scripts/ask_page";
  </script>

  <style>
    .ask-header {
      margin-bottom: var(--space-xl);
      padding-bottom: var(--space-lg);
      border-bottom: 1px solid var(--color-border);
    }
    .ask-header h1 {
      margin: 0 0 var(--space-xs) 0;
    }
    .place-context {
      margin: 0;
      color: var(--color-muted);
      font-size: var(--font-size-sm);
    }
    .place-context code {
      font-family: var(--font-sans);
      font-size: var(--font-size-xs);
      background: var(--color-bg);
      padding: var(--space-xs) var(--space-sm);
      border-radius: var(--radius-sm);
    }
    .ask-prompt {
      color: var(--color-muted);
      font-size: var(--font-size-lg);
    }
    .answer-surface {
      min-height: 4rem;
    }
    .answer-status {
      color: var(--color-muted);
      font-style: italic;
    }
    .answer-block {
      margin-bottom: var(--space-lg);
    }
    .answer-text {
      line-height: var(--line-height-relaxed);
    }
    .answer-text p {
      margin-bottom: var(--space-md);
    }
    .answer-text ul {
      margin-bottom: var(--space-md);
    }
    .inline-code {
      font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
      font-size: 0.9em;
      background: var(--color-bg);
      padding: 0.1em 0.4em;
      border-radius: var(--radius-sm);
      border: 1px solid var(--color-border-light);
    }
    .insight-callout {
      padding: var(--space-lg);
      border-radius: var(--radius);
      border-left: 4px solid var(--color-muted);
      margin-bottom: var(--space-lg);
      background: var(--color-surface);
      line-height: var(--line-height-relaxed);
    }
    .insight-callout.severity-notable {
      border-left-color: var(--color-accent);
      background: #f0f9f0;
    }
    .insight-callout.severity-extreme {
      border-left-color: #dc2626;
      background: #fee2e2;
    }
    .callout-headline {
      font-weight: var(--font-weight-semibold);
      margin: 0 0 var(--space-xs) 0;
    }
    .callout-evidence {
      margin: 0;
      font-size: var(--font-size-sm);
      color: var(--color-text-light);
    }
    .block-placeholder {
      padding: var(--space-lg);
      background: var(--color-surface);
      border: 1px dashed var(--color-border);
      border-radius: var(--radius);
      font-size: var(--font-size-sm);
      color: var(--color-muted);
      word-break: break-word;
    }
    .block-unknown {
      border-style: dotted;
    }
    .block-error {
      padding: var(--space-md);
      background: #fee2e2;
      color: #991b1b;
      border-radius: var(--radius);
      font-size: var(--font-size-sm);
    }
    /* indicator-card — mirrors components/IndicatorCard.astro so the
       inline-rendered card matches the SSR card styling. */
    .indicator-card {
      border: 1px solid var(--color-border-light);
      border-radius: var(--radius);
      padding: var(--space-lg);
      background: var(--color-surface);
      box-shadow: var(--shadow-sm);
    }
    .indicator-card header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: var(--space-sm);
    }
    .indicator-card h4 {
      margin: 0;
      font-size: var(--font-size-base);
      font-weight: var(--font-weight-medium);
      color: var(--color-primary);
    }
    .indicator-card .value-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: var(--space-md);
      margin-top: var(--space-md);
    }
    .indicator-card .value {
      margin: 0;
      font-size: var(--font-size-2xl);
      font-weight: var(--font-weight-semibold);
      color: var(--color-text);
    }
    .indicator-card .number {
      font-variant-numeric: tabular-nums;
    }
    .indicator-card .unit {
      font-size: var(--font-size-sm);
      color: var(--color-muted);
      margin-left: var(--space-xs);
    }
    .indicator-card .benchmark {
      display: flex;
      align-items: center;
      gap: var(--space-xs);
      padding: var(--space-xs) var(--space-sm);
      background: var(--color-bg);
      border-radius: var(--radius);
    }
    .indicator-card .benchmark .context {
      font-size: var(--font-size-lg);
      font-weight: var(--font-weight-semibold);
      color: var(--color-primary);
      font-variant-numeric: tabular-nums;
    }
    .indicator-card .benchmark .direction.good {
      color: #166534;
    }
    .indicator-card .benchmark .direction.bad {
      color: #991b1b;
    }
    .indicator-card .meta-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: var(--space-sm);
      margin-top: var(--space-xs);
    }
    .indicator-card .period {
      margin: 0;
      color: var(--color-muted);
      font-size: var(--font-size-sm);
    }
    .indicator-card .source-label {
      color: var(--color-text-light);
    }
    .indicator-card .confidence-badge {
      font-size: var(--font-size-xs);
      padding: var(--space-xs) var(--space-sm);
      border-radius: var(--radius-sm);
      text-transform: capitalize;
    }
    .indicator-card .confidence-badge.official {
      background: #dcfce7;
      color: #166534;
    }
    .indicator-card .confidence-badge.experimental {
      background: #fef3c7;
      color: #92400e;
    }
    .indicator-card .confidence-badge.modelled {
      background: #e0e7ff;
      color: #3730a3;
    }
    .indicator-card .caveats {
      font-size: var(--font-size-sm);
      color: var(--color-muted);
      margin: var(--space-md) 0 0;
      padding-left: var(--space-md);
    }
    .indicator-card .cache-status {
      font-size: var(--font-size-xs);
      font-weight: var(--font-weight-medium);
      padding: var(--space-xs) var(--space-sm);
      border-radius: var(--radius-sm);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      white-space: nowrap;
    }
    .indicator-card .cache-live {
      background: #dcfce7;
      color: #166534;
    }
    .indicator-card .cache-cached {
      background: #fef3c7;
      color: #92400e;
    }
    .indicator-card .cache-stale {
      background: #fee2e2;
      color: #991b1b;
    }
    /* chart blocks — responsive SVGs */
    .trend-chart-block {
      margin: 0;
    }
    .trend-chart-block .chart svg,
    .block-compare-chart .chart svg {
      width: 100%;
      height: auto;
    }
    .trend-chart-block figcaption {
      font-size: var(--font-size-xs);
      color: var(--color-muted);
      margin-top: var(--space-xs);
    }
    .compare-heading {
      margin: 0 0 var(--space-sm);
      font-size: var(--font-size-base);
      font-weight: var(--font-weight-medium);
      color: var(--color-primary);
    }
    /* organisations */
    .org-list {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }
    .org-card h4 {
      margin: 0 0 var(--space-xs);
      font-size: var(--font-size-base);
      color: var(--color-primary);
    }
    .org-grants {
      margin: var(--space-sm) 0 0;
      padding-left: var(--space-md);
      font-size: var(--font-size-sm);
      color: var(--color-text-light);
    }
    /* map */
    .map-container {
      width: 100%;
      height: 320px;
      border: 1px solid var(--color-border-light);
      border-radius: var(--radius);
      overflow: hidden;
    }
    .map-caption {
      margin: var(--space-xs) 0 0;
    }
    .answer-error {
      background: #fee2e2;
      color: #991b1b;
      padding: var(--space-lg);
      border-radius: var(--radius);
    }
    .answer-error a {
      color: #991b1b;
      font-weight: var(--font-weight-medium);
      text-decoration: underline;
    }
    .sources-footer {
      margin-top: var(--space-xl);
      padding-top: var(--space-lg);
      border-top: 1px solid var(--color-border-light);
      font-size: var(--font-size-sm);
    }
    .sources-footer h3 {
      font-size: var(--font-size-base);
      margin-bottom: var(--space-md);
    }
    .sources-footer ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .sources-footer li {
      padding: var(--space-sm) 0;
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-sm);
      align-items: center;
    }
    .source-publisher {
      color: var(--color-muted);
    }
  </style>
</Base>
