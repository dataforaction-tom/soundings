---
import Base from "../../layouts/Base.astro";
import DomainSection from "../../components/DomainSection.astro";
import SourceCitations from "../../components/SourceCitations.astro";
import DataPanel from "../../components/DataPanel.astro";
import { getPlaceProfile, getTrend } from "../../lib/api";
import { domainOf } from "../../lib/indicator_display";
import type {
  IndicatorValue,
  PlaceProfile,
  SourceRef,
  TrendPoint,
} from "../../lib/types";

export const prerender = false;

const placeId = decodeURIComponent(Astro.params.id ?? "");
const cookieHeader = Astro.request.headers.get("cookie") ?? undefined;

const include = ["population", "deprivation"];
let profile: PlaceProfile | null = null;
let error: string | null = null;

if (placeId) {
  try {
    profile = await getPlaceProfile(placeId, include, { cookieHeader });
  } catch (err) {
    error = err instanceof Error ? err.message : String(err);
  }
}

function groupByDomain(rows: IndicatorValue[]): Map<string, IndicatorValue[]> {
  const out = new Map<string, IndicatorValue[]>();
  for (const row of rows) {
    const domain = domainOf(row.indicator);
    const list = out.get(domain) ?? [];
    list.push(row);
    out.set(domain, list);
  }
  return out;
}

// Fan out trend requests for every indicator on the profile in parallel.
// The server returns `trend: null` cheaply when no series is available
// (loader-mode indicators with empty data.trend_point, passthrough
// indicators without a series), so a redundant request isn't expensive.
async function loadTrends(
  placeId: string,
  rows: IndicatorValue[],
  cookieHeader: string | undefined,
): Promise<Map<string, TrendPoint[]>> {
  const out = new Map<string, TrendPoint[]>();
  const settled = await Promise.allSettled(
    rows.map((row) =>
      getTrend(placeId, row.indicator, { cookieHeader }).then((response) => ({
        indicator: row.indicator,
        trend: response.trend,
      })),
    ),
  );
  for (const result of settled) {
    if (result.status !== "fulfilled" || result.value.trend === null) {
      continue;
    }
    out.set(result.value.indicator, result.value.trend.points);
  }
  return out;
}

const grouped = profile ? groupByDomain(profile.indicators) : new Map();
const trendsByIndicator: Map<string, TrendPoint[]> = profile
  ? await loadTrends(profile.place.id, profile.indicators, cookieHeader)
  : new Map();
const sources: SourceRef[] = profile
  ? profile.indicators.map((row) => row.source)
  : [];
---

<Base title={profile ? profile.place.name : placeId}>
  {error && (
    <p class="error">Couldn't load profile: {error}</p>
  )}

  {profile && (
    <>
      <header class="place-header">
        <h2>{profile.place.name}</h2>
        <p class="place-type">{profile.place.type} · <code>{profile.place.id}</code></p>
      </header>

      {profile.indicators.length === 0 ? (
        <p>No indicators available for this place yet.</p>
      ) : (
        [...grouped.entries()].map(([domain, indicators]) => (
          <DomainSection
            title={domain}
            indicators={indicators}
            trends={trendsByIndicator}
          />
        ))
      )}

      <SourceCitations sources={sources} />

      <DataPanel
        toolName="get_place_profile"
        request={{ place_id: profile.place.id, include }}
        response={profile}
      />
    </>
  )}

  <style>
    .place-header h2 {
      margin-bottom: 0.25rem;
    }
    .place-type {
      color: #555;
      margin-top: 0;
    }
    .error {
      color: #a00;
    }
  </style>
</Base>
