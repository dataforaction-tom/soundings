    /* ─── How it works ─── */
    .how-it-works {
      margin-bottom: var(--space-3xl);
    }
    .steps {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
      gap: var(--space-lg);
