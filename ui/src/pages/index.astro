---
import Base from "../layouts/Base.astro";
import AskBox from "../components/AskBox.astro";
import { findPlace } from "../lib/api";
import { readConsentFromCookieString } from "../lib/consent";
import type { PlaceMatch } from "../lib/types";

const url = new URL(Astro.request.url);
const query = (url.searchParams.get("q") ?? "").trim();
const cookieHeader = Astro.request.headers.get("cookie") ?? undefined;
const { consentLevel } = readConsentFromCookieString(cookieHeader);

let matches: PlaceMatch[] = [];
let error: string | null = null;

if (query) {
  try {
    const result = await findPlace(query, {
      cookieHeader,
      nlQuestion: consentLevel === "full" ? query : undefined,
    });
    matches = result.matches ?? [];
  } catch (err) {
    error = err instanceof Error ? err.message : String(err);
  }

  if (matches.length === 1) {
    return Astro.redirect(`/place/${encodeURIComponent(matches[0]!.id)}`);
  }
}
---

<Base title="Soundings">
  <p class="intro">Ask a question about a place — postcode, council, region.</p>
  <form class="search-form" method="get" action="/">
    <label>
      <span>What do you want to know about a place?</span>
      <input
        type="text"
        name="q"
        value={query}
        placeholder="Stockton-on-Tees, TS18 1AB, North Tyneside…"
        autofocus
        required
      />
    </label>
    <button type="submit">Search</button>
  </form>

  <AskBox />

  {error && (
    <p class="error">
      Sorry — couldn't reach the indicator service: {error}
    </p>
  )}

  {query && !error && matches.length === 0 && (
    <p class="no-match">
      No places matched <strong>{query}</strong>. Try a postcode, a full council
      name, or a region.
    </p>
  )}

  {matches.length > 1 && (
    <section>
      <h2>{matches.length} matches</h2>
      <ul class="match-list">
        {matches.map((m) => (
          <li>
            <a href={`/place/${encodeURIComponent(m.id)}`}>
              <strong>{m.name}</strong>
              <span class="match-type"> · {m.type}</span>
            </a>
            {m.parent_ids && m.parent_ids.length > 0 && (
              <span class="parents"> in {m.parent_ids.join(" → ")}</span>
            )}
          </li>
        ))}
      </ul>
    </section>
  )}

  <style>
    .intro {
      font-size: var(--font-size-lg);
      color: var(--color-text-light);
      margin-bottom: var(--space-xl);
    }
    .search-form {
      display: flex;
      gap: var(--space-md);
      align-items: end;
      margin-bottom: var(--space-xl);
    }
    .search-form label {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: var(--space-sm);
    }
    .search-form label span {
      font-weight: var(--font-weight-medium);
      color: var(--color-primary);
    }
    .search-form input[type="text"] {
      padding: var(--space-md);
      font-size: var(--font-size-lg);
    }
    .search-form button {
      padding: var(--space-md) var(--space-xl);
      height: fit-content;
    }
    .match-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .match-list li {
      padding: var(--space-md) 0;
      border-bottom: 1px solid var(--color-border-light);
    }
    .match-list li:last-child {
      border-bottom: none;
    }
    .match-list a {
      display: block;
      padding: var(--space-sm) 0;
    }
    .match-list strong {
      font-size: var(--font-size-lg);
    }
    .match-type {
      color: var(--color-muted);
      font-variant: small-caps;
    }
    .parents {
      color: var(--color-muted);
      font-size: var(--font-size-sm);
      margin-left: var(--space-sm);
    }
    .no-match,
    .error {
      margin: var(--space-md) 0;
      padding: var(--space-lg);
      border-radius: var(--radius);
    }
    .error {
      background: #fee2e2;
      color: #991b1b;
    }
    .no-match {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
    }
  </style>
</Base>
