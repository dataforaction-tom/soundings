---
import OrganisationCard from "./OrganisationCard.astro";
import SourceCitations from "./SourceCitations.astro";
import { findOrganisationsInPlace } from "../lib/api";
import type { OrganisationRef, SourceRef } from "../lib/types";

interface Props {
  placeId: string;
  cookieHeader?: string;
}

const { placeId, cookieHeader } = Astro.props;

// Skip non-England/Wales places - they won't have CC data
// FTC handles Scotland/NI but we'll silently skip for now if empty
const isEnglandOrWales = placeId.startsWith("ltla24:E") || placeId.startsWith("ltla24:W");

let organisations: OrganisationRef[] = [];
let sources: SourceRef[] = [];
let caveats: string[] = [];
let partial = false;
let error = null;

if (isEnglandOrWales) {
  try {
    const response = await findOrganisationsInPlace(placeId, {
      limit: 10,
      cookieHeader,
    });
    organisations = response.organisations;
    sources = response.sources;
    caveats = response.caveats;
    partial = response.partial;
  } catch (err) {
    // Silently fail - organisations section is non-critical
    error = err instanceof Error ? err.message : String(err);
  }
}

const showSection = organisations.length > 0;
---

{showSection && (
  <section class="organisations-section">
    <h3>Organisations</h3>
    <p class="intro">
      {organisations.length} organisation{organisations.length === 1 ? "" : "s"}
      {partial && " (partial results)"}
      {" "}found in this area from Charity Commission data.
    </p>

    <div class="org-grid">
      {organisations.map((org) => (
        <OrganisationCard organisation={org} />
      ))}
    </div>

    {caveats.length > 0 && (
      <ul class="caveats">
        {caveats.map((c) => <li>{c}</li>)}
      </ul>
    )}

    {sources.length > 0 && <SourceCitations sources={sources} />}
  </section>
)}

<style>
  .organisations-section {
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }
  .organisations-section h3 {
    margin: 0 0 var(--space-md);
    font-size: var(--font-size-xl);
    color: var(--color-primary);
  }
  .intro {
    margin: 0 0 var(--space-lg);
    color: var(--color-muted);
    font-size: var(--font-size-sm);
  }
  .org-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-lg);
  }
  .caveats {
    margin: var(--space-lg) 0 0;
    padding-left: var(--space-lg);
    font-size: var(--font-size-sm);
    color: var(--color-muted);
  }
  .caveats li {
    margin: var(--space-xs) 0;
  }
</style>
