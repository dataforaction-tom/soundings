---
import "../lib/dom-polyfill";
import { renderCompareBars } from "../lib/chart";
import { prettyKey } from "../lib/indicator_display";
import type { Comparison, ComparisonBasis } from "../lib/types";

interface Props {
  comparison: Comparison;
  basis?: ComparisonBasis;
}

const { comparison, basis } = Astro.props;
const svg = renderCompareBars(comparison, { basis });
---

<section class="compare-chart">
  <header>
    <h3>{prettyKey(comparison.indicator)}</h3>
    <p class="meta">
      {comparison.period}
      <span aria-hidden="true"> · </span>
      <span class="unit">{comparison.unit}</span>
      <span aria-hidden="true"> · </span>
      <a href={comparison.source.dataset_url || comparison.source.publisher_url || "#"}>
        {comparison.source.source_label}
      </a>
    </p>
  </header>
  {svg ? (
    <div class="chart" set:html={svg} />
  ) : (
    <p class="no-data">No values returned for the selected places.</p>
  )}
  {comparison.caveats.length > 0 && (
    <ul class="caveats">
      {comparison.caveats.map((c) => <li>{c}</li>)}
    </ul>
  )}
</section>

<style>
  .compare-chart {
    margin: var(--space-lg) 0;
    padding: var(--space-lg);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius);
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
  }
  .compare-chart header {
    margin-bottom: var(--space-md);
  }
  .compare-chart h3 {
    margin: 0;
    text-transform: capitalize;
    font-size: var(--font-size-lg);
    color: var(--color-primary);
  }
  .compare-chart .meta {
    margin: var(--space-xs) 0 0;
    color: var(--color-muted);
    font-size: var(--font-size-sm);
  }
  .compare-chart .chart {
    overflow-x: auto;
  }
  .compare-chart .chart svg {
    width: 100%;
    height: auto;
  }
  .compare-chart .no-data {
    color: var(--color-muted);
    font-style: italic;
  }
  .compare-chart .caveats {
    font-size: var(--font-size-sm);
    color: var(--color-muted);
    margin: var(--space-md) 0 0;
    padding-left: var(--space-md);
  }
</style>
