---
import IncomeBucketsChart from "./IncomeBucketsChart.astro";
import RegistrationTrendChart from "./RegistrationTrendChart.astro";
import SourceCitations from "./SourceCitations.astro";
import { getCivilSocietyProfile } from "../lib/api";
import type { CivilSocietyProfile, NotableOrg, FunderSummary, GrantYearSummary, CauseAreaCount } from "../lib/types";

interface Props {
  placeId: string;
  cookieHeader?: string;
}

const { placeId, cookieHeader } = Astro.props;

// CC bulk register covers England + Wales registered charities only.
// Skip the panel entirely for Scotland / NI place ids so we don't show
// an honest-but-misleading "0 charities" for County Durham equivalents.
const isEnglandOrWales =
  placeId.startsWith("ltla24:E") || placeId.startsWith("ltla24:W") ||
  placeId.startsWith("utla24:E") || placeId.startsWith("utla24:W");

let profile: CivilSocietyProfile | null = null;
let error: string | null = null;

if (isEnglandOrWales) {
  try {
    profile = await getCivilSocietyProfile(placeId, { cookieHeader });
  } catch (err) {
    error = err instanceof Error ? err.message : String(err);
  }
}

function fmtGBP(value: number | null): string {
  if (value === null) return "—";
  return new Intl.NumberFormat("en-GB", {
    style: "currency",
    currency: "GBP",
    maximumFractionDigits: 0,
  }).format(value);
}

function fmtInt(value: number): string {
  return new Intl.NumberFormat("en-GB").format(value);
}
---

{error && (
  <p class="error">Couldn't load civil society profile: {error}</p>
)}

{profile && profile.total_organisations > 0 && (
  <section class="cs-panel">
    <h3>Civil society</h3>

    <div class="cs-headlines">
      <div class="cs-stat">
        <span class="stat-value">{fmtInt(profile.total_organisations)}</span>
        <span class="stat-label">charities operating here</span>
      </div>
      <div class="cs-stat">
        <span class="stat-value">{fmtInt(profile.registered_address_count)}</span>
        <span class="stat-label">registered in this place</span>
      </div>
      <div class="cs-stat">
        <span class="stat-value">{fmtGBP(profile.median_income)}</span>
        <span class="stat-label">median annual income</span>
      </div>
      <div class="cs-stat">
        <span class="stat-value">{fmtGBP(profile.mean_income)}</span>
        <span class="stat-label">mean annual income</span>
      </div>
    </div>

    <div class="cs-charts">
      <div>
        <h4>Income distribution</h4>
        <IncomeBucketsChart buckets={profile.income_buckets} />
      </div>
      <div>
        <h4>Net new charities per year</h4>
        <RegistrationTrendChart cohort={profile.registration_cohort} />
      </div>
    </div>

    {profile.notable && (profile.notable.oldest || profile.notable.largest) && (
      <div class="cs-notable">
        <h4>Standout charities</h4>
        <div class="cs-notable-grid">
          {profile.notable.oldest && (
            <div class="cs-notable-card">
              <span class="stat-label">Oldest</span>
              <span class="cs-notable-name">{profile.notable.oldest.name}</span>
              {profile.notable.oldest.year_registered && (
                <span class="text-muted">Founded {profile.notable.oldest.year_registered}</span>
              )}
            </div>
          )}
          {profile.notable.largest && (
            <div class="cs-notable-card">
              <span class="stat-label">Largest by income</span>
              <span class="cs-notable-name">{profile.notable.largest.name}</span>
              <span class="text-muted">{fmtGBP(profile.notable.largest.latest_income)}/yr</span>
            </div>
          )}
          {profile.notable.newest && (
            <div class="cs-notable-card">
              <span class="stat-label">Newest</span>
              <span class="cs-notable-name">{profile.notable.newest.name}</span>
              {profile.notable.newest.year_registered && (
                <span class="text-muted">Registered {profile.notable.newest.year_registered}</span>
              )}
            </div>
          )}
          {profile.notable.income_concentration_top3_pct !== null && (
            <div class="cs-notable-card">
              <span class="stat-label">Income concentration</span>
              <span class="cs-notable-name">{profile.notable.income_concentration_top3_pct}%</span>
              <span class="text-muted">held by top 3 charities</span>
            </div>
          )}
        </div>
      </div>
    )}

    {profile.cause_area_distribution.length > 0 && (
      <div class="cs-cause-areas">
        <h4>Charity causes</h4>
        <ul class="cause-list">
          {profile.cause_area_distribution.slice(0, 8).map((area: CauseAreaCount) => (
            <li>
              <span class="cause-label">{area.label.length > 80 ? area.label.slice(0, 80) + "…" : area.label}</span>
              <span class="cause-count">{area.count}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    {profile.top_funders.length > 0 && (
      <div class="cs-funders">
        <h4>Top funders (last 12 months)</h4>
        <ul class="funder-list">
          {profile.top_funders.slice(0, 10).map((f: FunderSummary) => (
            <li>
              <span class="funder-name">{f.name}</span>
              <span class="funder-detail">{f.grant_count} grants · {fmtGBP(f.total_gbp)}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    {profile.grants_by_year.length > 0 && (
      <div class="cs-grants-trend">
        <h4>Grants by year</h4>
        <div class="grant-bars">
          {profile.grants_by_year.map((g: GrantYearSummary) => {
            const maxGbp = Math.max(...profile.grants_by_year.map(x => x.total_gbp), 1);
            const pct = Math.round((g.total_gbp / maxGbp) * 100);
            return (
              <div class="grant-bar-row">
                <span class="grant-year">{g.year}</span>
                <div class="grant-bar-track">
                  <div class="grant-bar-fill" style={`width: ${pct}%`}></div>
                </div>
                <span class="grant-amount">{fmtGBP(g.total_gbp)}</span>
              </div>
            );
          })}
        </div>
      </div>
    )}

    {profile.caveats.length > 0 && (
      <ul class="caveats">
        {profile.caveats.map((c) => <li>{c}</li>)}
      </ul>
    )}

    {profile.sources.length > 0 && <SourceCitations sources={profile.sources} />}
  </section>
)}

<style>
  .cs-panel {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }
  .cs-panel h3 {
    margin: 0 0 1rem;
    font-size: 1.25rem;
  }
  .cs-panel h4 {
    margin: 0 0 0.5rem;
    font-size: 0.9375rem;
    color: var(--color-muted);
  }
  .cs-headlines {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .cs-stat {
    display: flex;
    flex-direction: column;
    padding: 0.75rem 1rem;
    background: var(--color-bg);
    border-radius: 6px;
  }
  .stat-value {
    font-size: 1.5rem;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
  }
  .stat-label {
    font-size: 0.8125rem;
    color: var(--color-muted);
    margin-top: 0.125rem;
  }
  .cs-charts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
    gap: 1.5rem;
  }
  .caveats {
    margin: 1rem 0 0;
    padding-left: 1rem;
    font-size: 0.8125rem;
    color: var(--color-muted);
  }
  .error { color: #a00; }

  .cs-notable {
    margin-top: 1.5rem;
  }
  .cs-notable-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.75rem;
  }
  .cs-notable-card {
    display: flex;
    flex-direction: column;
    padding: 0.75rem 1rem;
    background: var(--color-bg);
    border-radius: 6px;
  }
  .cs-notable-name {
    font-size: 0.9375rem;
    font-weight: 500;
    margin: 0.125rem 0;
  }
  .cs-cause-areas,
  .cs-funders,
  .cs-grants-trend {
    margin-top: 1.5rem;
  }
  .cause-list,
  .funder-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .cause-list li,
  .funder-list li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.375rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .cause-label {
    font-size: 0.875rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin-right: 1rem;
  }
  .cause-count {
    font-variant-numeric: tabular-nums;
    font-weight: 500;
    flex-shrink: 0;
  }
  .funder-name {
    font-size: 0.875rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin-right: 1rem;
  }
  .funder-detail {
    font-size: 0.8125rem;
    color: var(--color-muted);
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }
  .grant-bars {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .grant-bar-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8125rem;
  }
  .grant-year {
    width: 3rem;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
    color: var(--color-muted);
  }
  .grant-bar-track {
    flex: 1;
    height: 1rem;
    background: var(--color-bg);
    border-radius: 3px;
    overflow: hidden;
  }
  .grant-bar-fill {
    height: 100%;
    background: var(--color-primary, #1a2f4e);
    border-radius: 3px;
  }
  .grant-amount {
    width: 5rem;
    flex-shrink: 0;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
</style>
