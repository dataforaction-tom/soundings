---
interface Props {
  toolName: string;
  request: object;
  response: object;
}

const { toolName, request, response } = Astro.props;
---

<details class="data-panel">
  <summary>Data behind this · {toolName}</summary>
  <h4>Request</h4>
  <pre><code>{JSON.stringify(request, null, 2)}</code></pre>
  <h4>Response</h4>
  <pre><code>{JSON.stringify(response, null, 2)}</code></pre>
</details>

<style>
  .data-panel {
    margin: var(--space-xl) 0;
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius);
    background: var(--color-bg);
    overflow: hidden;
  }
  .data-panel summary {
    cursor: pointer;
    font-weight: var(--font-weight-medium);
    padding: var(--space-md);
    color: var(--color-muted);
    font-size: var(--font-size-sm);
  }
  .data-panel summary:hover {
    background: var(--color-surface);
  }
  .data-panel[open] summary {
    border-bottom: 1px solid var(--color-border-light);
  }
  .data-panel h4 {
    margin: var(--space-md) var(--space-lg) var(--space-sm);
    font-size: var(--font-size-sm);
    color: var(--color-muted);
  }
  .data-panel pre {
    margin: 0 var(--space-lg) var(--space-lg);
    overflow-x: auto;
    font-size: var(--font-size-xs);
    background: var(--color-surface);
    padding: var(--space-md);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-sm);
  }
</style>
