---
import IndicatorCard from "./IndicatorCard.astro";
import type { IndicatorValue, TrendPoint } from "../lib/types";

interface Props {
  title: string;
  indicators: IndicatorValue[];
  trends?: Map<string, TrendPoint[]>;
}

const { title, indicators, trends } = Astro.props;
---

{indicators.length > 0 && (
  <section class="domain-section">
    <h3>{title}</h3>
    <div class="domain-grid">
      {indicators.map((ind) => (
        <IndicatorCard
          indicator={ind}
          trend={trends?.get(ind.indicator)}
        />
      ))}
    </div>
  </section>
)}

<style>
  .domain-section {
    margin: 1.5rem 0;
  }
  .domain-section h3 {
    text-transform: capitalize;
    margin-bottom: 0.5rem;
  }
  .domain-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
    gap: 0.75rem;
  }
</style>
