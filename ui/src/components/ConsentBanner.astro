---
import { readConsentFromCookieString } from "../lib/consent";

const cookieHeader = Astro.request.headers.get("cookie");
const { consentLevel } = readConsentFromCookieString(cookieHeader);
---

{consentLevel !== "full" && (
  <aside class="consent-banner">
    <p>
      Soundings logs every question to a public, open corpus.
      <a href="/about">Learn how capture works</a> or
      <a href="/corpus">browse the corpus</a>.
    </p>
  </aside>
)}

<style>
  .consent-banner {
    padding: var(--space-sm) var(--space-lg);
    margin-bottom: var(--space-lg);
    background: rgba(74, 124, 89, 0.08);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
  }
  .consent-banner a {
    font-weight: var(--font-weight-medium);
  }
</style>
