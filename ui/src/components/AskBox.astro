---
interface Props {
  placeId?: string;
  placeName?: string;
}

const { placeId, placeName } = Astro.props;
const hasPlace = Boolean(placeId);

// Example questions — these fill the input and submit, teaching the user
// what kinds of questions work.  The model infers intent from the text.
const examplesWithPlace = [
  "Summarise this place",
  "How does it compare to peers?",
  "What are the most deprived neighbourhoods here?",
  "Where are the food banks?",
];

const examplesNoPlace = [
  "Summarise Stockton-on-Tees",
  "How does Sheffield compare to peers?",
  "Most deprived neighbourhoods in Middlesbrough",
  "Where are the food banks in Leeds?",
];
const examples = hasPlace ? examplesWithPlace : examplesNoPlace;
---

<form class="ask-box" method="get" action="/ask">
  <div class="ask-input-row">
    <input
      type="text"
      name="q"
      class="ask-input"
      placeholder={hasPlace && placeName
        ? `Ask about ${placeName}…`
        : "Ask a question about a place…"}
      autocomplete="off"
      required
    />
    {hasPlace && <input type="hidden" name="place_id" value={placeId} />}
    <button type="submit" class="ask-submit">Ask</button>
  </div>

  <div class="example-chips" role="group" aria-label="Example questions">
    {examples.map((q) => (
      <button type="button" class="example-chip" data-example={q}>
        {q}
      </button>
    ))}
  </div>
</form>

<script>
  function initAskBox(root: HTMLElement) {
    const chips = root.querySelectorAll<HTMLButtonElement>(".example-chip");
    const qInput = root.querySelector<HTMLInputElement>("input[name='q']");
    const form = root.querySelector<HTMLFormElement>(".ask-box");
    if (!qInput || !form) return;

    for (const chip of chips) {
      chip.addEventListener("click", () => {
        qInput.value = chip.dataset.example ?? "";
        form.requestSubmit();
      });
    }
  }

  document
    .querySelectorAll<HTMLElement>(".ask-box")
    .forEach(initAskBox);
</script>

<style>
  .ask-box {
    margin-bottom: var(--space-xl);
  }
  .ask-input-row {
    display: flex;
    gap: var(--space-md);
    align-items: stretch;
    margin-bottom: var(--space-md);
  }
  .ask-input {
    flex: 1;
    padding: var(--space-md);
    font-size: var(--font-size-lg);
  }
  .ask-submit {
    padding: var(--space-md) var(--space-xl);
  }
  .example-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    align-items: center;
  }
  .example-chip {
    display: inline-flex;
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    cursor: pointer;
    transition: background-color 0.15s ease, border-color 0.15s ease;
  }
  .example-chip:hover {
    background: var(--color-bg);
    border-color: var(--color-accent);
  }
</style>
