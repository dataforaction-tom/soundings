---
import type { SourceRef } from "../lib/types";
import { dedupeSources } from "../lib/sources";

interface Props {
  sources: SourceRef[];
}

const { sources } = Astro.props;
const unique = dedupeSources(sources);
---

{unique.length > 0 && (
  <section class="source-citations">
    <h3>Sources</h3>
    <ul>
      {unique.map((ref) => (
        <li>
          <a href={ref.dataset_url} target="_blank" rel="noopener">
            {ref.source_label || ref.source_id}
          </a>
          <span class="publisher"> · {ref.publisher}</span>
          <span class={`cache-status cache-${ref.cache_status}`}>
            {ref.cache_status}
          </span>
          <span class="retrieved">
            retrieved {ref.retrieved_at.slice(0, 10)}
          </span>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .source-citations {
    margin: var(--space-xl) 0;
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border-light);
    font-size: var(--font-size-sm);
  }
  .source-citations h3 {
    font-size: var(--font-size-base);
    margin-bottom: var(--space-md);
  }
  .source-citations ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .source-citations li {
    padding: var(--space-sm) 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    align-items: center;
  }
  .publisher,
  .retrieved {
    color: var(--color-muted);
  }
  .cache-status {
    display: inline-block;
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .cache-live {
    background: #dcfce7;
    color: #166534;
  }
  .cache-cached {
    background: #fef3c7;
    color: #92400e;
  }
  .cache-stale {
    background: #fee2e2;
    color: #991b1b;
  }
</style>
