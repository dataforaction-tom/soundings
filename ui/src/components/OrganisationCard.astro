---
import type { OrganisationRef, GrantRef } from "../lib/types";

interface Props {
  organisation: OrganisationRef;
}

const { organisation } = Astro.props;

function formatAmount(amount: number): string {
  return new Intl.NumberFormat("en-GB", {
    style: "currency",
    currency: "GBP",
    maximumFractionDigits: 0,
  }).format(amount);
}

function formatDate(dateStr: string): string {
  try {
    return new Date(dateStr).toLocaleDateString("en-GB", {
      year: "numeric",
      month: "short",
    });
  } catch {
    return dateStr;
  }
}

const topGrants = organisation.recent_grants.slice(0, 3);

const foundedYear = organisation.date_of_registration
  ? organisation.date_of_registration.substring(0, 4)
  : null;
---

<article class="organisation-card">
  <header>
    <h4>
      {organisation.register_url ? (
        <a href={organisation.register_url} target="_blank" rel="noopener noreferrer">
          {organisation.name}
        </a>
      ) : (
        organisation.name
      )}
    </h4>
    <span class="source-label">{organisation.source.source_label}</span>
  </header>

  {organisation.latest_income !== null && organisation.latest_income !== undefined && (
    <p class="income">
      {new Intl.NumberFormat("en-GB", {
        style: "currency",
        currency: "GBP",
        maximumFractionDigits: 0,
      }).format(organisation.latest_income)}/yr
    </p>
  )}

  {foundedYear && (
    <p class="founded text-muted text-small">Founded {foundedYear}</p>
  )}

  {organisation.classification.length > 0 && (
    <div class="classifications">
      {organisation.classification.map((c) => (
        <span class="tag">{c}</span>
      ))}
    </div>
  )}

  {topGrants.length > 0 && (
    <div class="grants">
      <h5>Recent grants</h5>
      <ul>
        {topGrants.map((grant: GrantRef) => (
          <li>
            <span class="funder">{grant.funder}</span>
            <span class="amount">{formatAmount(grant.amount)}</span>
            <span class="date">{formatDate(grant.date)}</span>
          </li>
        ))}
      </ul>
    </div>
  )}

  {organisation.methodology_note && (
    <p class="note">{organisation.methodology_note}</p>
  )}
</article>

<style>
  .organisation-card {
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius);
    padding: var(--space-lg);
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
  }
  .organisation-card header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-sm);
  }
  .organisation-card h4 {
    margin: 0;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    color: var(--color-primary);
  }
  .source-label {
    font-size: var(--font-size-xs);
    color: var(--color-muted);
  }
  .income {
    margin: var(--space-xs) 0 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
  }
  .founded {
    margin: var(--space-xs) 0 0;
    font-size: var(--font-size-xs);
  }
  .organisation-card h4 a {
    color: var(--color-primary);
    text-decoration: none;
  }
  .organisation-card h4 a:hover {
    text-decoration: underline;
  }
  .classifications {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: var(--space-md);
  }
  .tag {
    font-size: var(--font-size-xs);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
    background: #e8f0f8;
    color: #2c5282;
  }
  .grants {
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border-light);
  }
  .grants h5 {
    margin: 0 0 var(--space-sm);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-muted);
  }
  .grants ul {
    margin: 0;
    padding-left: 0;
    list-style: none;
  }
  .grants li {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: var(--space-md);
    font-size: var(--font-size-sm);
    padding: var(--space-xs) 0;
  }
  .funder {
    color: var(--color-text);
  }
  .amount {
    font-variant-numeric: tabular-nums;
    font-weight: var(--font-weight-medium);
  }
  .date {
    color: var(--color-muted);
    font-size: var(--font-size-xs);
  }
  .note {
    margin: var(--space-md) 0 0;
    font-size: var(--font-size-xs);
    color: var(--color-muted);
    font-style: italic;
  }
</style>
