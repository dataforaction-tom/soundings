---
import IndicatorChart from "./IndicatorChart.astro";
import type { IndicatorValue, TrendPoint } from "../lib/types";
import { formatValue, prettyKey, formatContext, formatDirection } from "../lib/indicator_display";

interface Props {
  indicator: IndicatorValue;
  trend?: TrendPoint[];
}

const { indicator, trend } = Astro.props;
const hasTrend = trend !== undefined && trend.length >= 2;
const benchmark = indicator.benchmark_percentile;
const higherIs = indicator.higher_is ?? null;
const direction = formatDirection(higherIs);
// "good" if a high percentile is desirable; "bad" otherwise. Only set
// when the catalogue's higher_is has an opinion (better/worse).
const directionTone =
  higherIs === "better" ? "good" : higherIs === "worse" ? "bad" : "";
---

<article class="indicator-card">
  <header>
    <h4>{prettyKey(indicator.indicator)}</h4>
    <span class={`cache-status cache-${indicator.source.cache_status}`}>
      {indicator.source.cache_status}
    </span>
  </header>
  <div class="value-row">
    <p class="value">
      <span class="number">{formatValue(indicator.value)}</span>
      {indicator.unit && <span class="unit">{indicator.unit}</span>}
    </p>
    {benchmark !== null && benchmark !== undefined && (
      <div class="benchmark" title="Percentile against peer places of the same type">
        <span class="context">{formatContext(benchmark, "percentile")}</span>
        {direction && <span class={`direction ${directionTone}`}>{direction}</span>}
      </div>
    )}
  </div>
  <div class="meta-row">
    <p class="period">
      {indicator.period} · <span class="source-label">{indicator.source.source_label}</span>
    </p>
    <span class={`confidence-badge ${indicator.confidence}`} title="Data confidence level">
      {indicator.confidence}
    </span>
  </div>
  {hasTrend && (
    <IndicatorChart points={trend!} />
  )}
  {indicator.caveats.length > 0 && (
    <ul class="caveats">
      {indicator.caveats.map((c) => <li>{c}</li>)}
    </ul>
  )}
</article>

<style>
  .indicator-card {
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius);
    padding: var(--space-lg);
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.15s ease;
  }
  .indicator-card:hover {
    box-shadow: var(--shadow);
  }
  .indicator-card header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-sm);
  }
  .indicator-card h4 {
    margin: 0;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    color: var(--color-primary);
  }
  .value-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-md);
    margin-top: var(--space-md);
  }
  .value {
    margin: 0;
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
  }
  .number {
    font-variant-numeric: tabular-nums;
  }
  .unit {
    font-size: var(--font-size-sm);
    color: var(--color-muted);
    margin-left: var(--space-xs);
  }
  .benchmark {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-xs) var(--space-sm);
    background: var(--color-bg);
    border-radius: var(--radius);
  }
  .benchmark .context {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-primary);
    font-variant-numeric: tabular-nums;
  }
  .benchmark .direction {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
  }
  .benchmark .direction.good {
    color: #166534;
  }
  .benchmark .direction.bad {
    color: #991b1b;
  }
  .meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }
  .period {
    margin: 0;
    color: var(--color-muted);
    font-size: var(--font-size-sm);
  }
  .source-label {
    color: var(--color-text-light);
  }
  .confidence-badge {
    font-size: var(--font-size-xs);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
    text-transform: capitalize;
    letter-spacing: 0.02em;
  }
  .confidence-badge.official {
    background: #dcfce7;
    color: #166534;
  }
  .confidence-badge.experimental {
    background: #fef3c7;
    color: #92400e;
  }
  .confidence-badge.modelled {
    background: #e0e7ff;
    color: #3730a3;
  }
  .caveats {
    font-size: var(--font-size-sm);
    color: var(--color-muted);
    margin: var(--space-md) 0 0;
    padding-left: var(--space-md);
  }
  .cache-status {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }
  .cache-live {
    background: #dcfce7;
    color: #166534;
  }
  .cache-cached {
    background: #fef3c7;
    color: #92400e;
  }
  .cache-stale {
    background: #fee2e2;
    color: #991b1b;
  }
</style>
