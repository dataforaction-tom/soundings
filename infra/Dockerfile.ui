# Build the Astro app in one stage, run it in a thinner one.

FROM node:20-alpine AS build

WORKDIR /app
COPY ui/package.json ui/package-lock.json ./
# Don't omit optional deps: Rollup's platform-specific native binary
# (`@rollup/rollup-linux-arm64-musl` on Alpine arm64) is an optional dep,
# but Vite/Astro need it at build time.
# https://github.com/npm/cli/issues/4828
RUN npm ci

COPY ui/ ./
RUN npm run build

FROM node:20-alpine AS run

ENV NODE_ENV=production \
    HOST=0.0.0.0 \
    PORT=4321

WORKDIR /app
COPY --from=build /app/dist ./dist
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/package.json ./package.json

EXPOSE 4321
CMD ["node", "./dist/server/entry.mjs"]
